# vidscribe - ASR Provider Credentials
# Copy this file to .env and fill in your keys.
# Only configure the provider(s) you want to use.

# --- Volcengine (火山引擎) ---
# Best for Chinese content. ~0.8 CNY/hour.
# Get credentials: https://console.volcengine.com/speech/service/8
# VOLC_APP_KEY=your_app_id
# VOLC_ACCESS_KEY=your_access_token

# --- OpenAI Whisper API ---
# Best multilingual quality. $0.006/min.
# Get API key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# --- Aliyun DashScope (阿里云百炼) ---
# Good for Chinese. Free trial 3 months.
# Get API key: https://bailian.console.aliyun.com/
# DASHSCOPE_API_KEY=sk-...

# --- Deepgram ---
# Fastest & cheapest. $200 free credit on signup.
# Get API key: https://console.deepgram.com/
# DEEPGRAM_API_KEY=...

# --- Local (faster-whisper) ---
# No API key needed. Install with: pip install vidscribe[local]
